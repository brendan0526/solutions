<section style="padding-top:0;">
  <div class="wrap">
    <form class="form-panel" id="quote-form" style="max-width:800px;">

      <h3 style="margin-bottom:24px;">Your Contact Info</h3>
      <div class="form-grid" style="margin-bottom:32px;">
        <div class="form-field">
          <label for="name">Full name</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="form-field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="form-field">
          <label for="phone">Phone number</label>
          <input type="tel" id="phone" name="phone" required>
        </div>
        <div class="form-field">
          <label for="zip">ZIP code</label>
          <input type="text" id="zip" name="zip" placeholder="e.g. 85001">
        </div>
      </div>

      <h3 style="margin-bottom:24px;">What do you need covered?</h3>
      <div class="checkbox-grid" style="margin-bottom:32px;">
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="Auto"> 🚗 Auto</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="Home"> 🏠 Home</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="Renters"> 🔑 Renters</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="Motorcycle"> 🏍️ Motorcycle</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="SR22"> 📋 SR-22</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="Landlord"> 🏡 Landlord</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="GL"> 🛡️ General Liability</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="BOP"> 📦 BOP</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="Contractor"> 👷 Contractor</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="WorkersComp"> 👥 Workers' Comp</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="CommercialAuto"> 🚚 Commercial Auto</label>
        <label class="checkbox-item"><input type="checkbox" name="coverage" value="Other"> ➕ Other / Not sure</label>
      </div>

      <div class="form-field full" style="margin-bottom:32px;">
        <label for="notes">Anything we should know? (optional)</label>
        <textarea id="notes" name="notes" rows="3"></textarea>
      </div>

      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; font-size:1rem; padding:18px;">Get my free quote →</button>
      <p style="font-size:0.78rem; color:var(--taupe); margin-top:14px; line-height:1.5;">By submitting, you consent to be contacted by MDL Insurance Solutions by phone, email, or text regarding your quote request, even if your number is on a Do Not Call registry. This is not a condition of purchase. View our <a href="privacy.html" style="color:var(--terracotta-dark); text-decoration:underline;">Privacy Policy</a>.</p>
    </form>

    <div id="form-success" style="display:none; text-align:center; padding:80px 20px; max-width:560px; margin:0 auto;">
      <div style="font-size:3rem; margin-bottom:20px;">✅</div>
      <h2 style="margin-bottom:14px;">Got it — we're on it.</h2>
      <p style="font-size:1.05rem;">Someone from MDL will follow up within one business day with real options for your coverage. If you need something faster, call us directly at <a href="tel:+14804363529" style="color:var(--terracotta-dark); font-weight:700;">(480) 436-3529</a>.</p>
    </div>
  </div>
</section>

<footer>
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-col">
        <h4>MDL Insurance Solutions</h4>
        <p>Independent insurance agency serving Phoenix, Scottsdale, Mesa, and surrounding areas. Licensed in Arizona.</p>
        <p style="margin-top:12px;">NPN: 21218944</p>
      </div>
      <div class="footer-col">
        <h4>Personal</h4>
        <a href="personal.html">Auto Insurance</a>
        <a href="personal.html">Home Insurance</a>
        <a href="personal.html">Renters Insurance</a>
