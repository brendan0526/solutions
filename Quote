</footer>

<script>
document.getElementById('quote-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  var form = this;
  var submitBtn = form.querySelector('button[type="submit"]');
  submitBtn.textContent = 'Sending...';
  submitBtn.disabled = true;

  var coverages = Array.from(form.querySelectorAll('input[name="coverage"]:checked'))
                       .map(function(cb) { return cb.value; }).join(', ') || 'None selected';

  var payload = {
    access_key: 'ec1e66be-d7bb-4315-ad79-1dcffc0374ff',
    subject: 'New Quote Request — MDL Insurance Solutions',
    from_name: 'MDL Insurance Solutions Website',
    name:      form.querySelector('#name').value,
    email:     form.querySelector('#email').value,
    phone:     form.querySelector('#phone').value,
    zip:       form.querySelector('#zip').value,
    coverages: coverages,
    notes:     form.querySelector('#notes').value || 'None'
  };

  try {
    var res = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(payload)
    });
    var data = await res.json();
    if (data.success) {
      form.style.display = 'none';
      document.getElementById('form-success').style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } else {
      throw new Error(data.message || 'Submission failed');
    }
  } catch (err) {
    submitBtn.textContent = 'Something went wrong — please call (480) 436-3529';
    submitBtn.style.background = 'var(--sage)';
    submitBtn.disabled = false;
  }
});

(function() {
  var toggle = document.querySelector('.mobile-toggle');
  var menu = document.getElementById('mobile-nav');
  if (!toggle || !menu) return;
  toggle.addEventListener('click', function() {
    var isOpen = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    toggle.textContent = isOpen ? '×' : '≡';
  });
})();
</script>

</body>
